# Example environment variables for NSS project
# Copy this file to `.env` and fill with real values (do NOT commit secrets).

# Server
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/nss-portal

# Authentication
JWT_SECRET=your_jwt_secret_here

# Frontend
FRONTEND_URL=http://localhost:3000

# Email (Brevo / Sendinblue)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=sender@example.com

# Gemini / Google Generative AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Proxy / Trust
TRUST_PROXY=1
MAX_PROXY_CHAIN=5

# Body size limits
JSON_BODY_LIMIT=100kb
URLENCODED_BODY_LIMIT=100kb
PARAMETER_LIMIT=1000

# Rate limits (ms or counts)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30

# Timeouts (ms)
HEADERS_TIMEOUT_MS=65000
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=5000
